{
  "name": "site-builder",
  "version": "1.0.0",
  "description": "Объединенное приложение для генерации контента, изображений и сборки сайтов",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"node scripts/wait-for-api.mjs && npm run client\"",
    "server": "tsx watch --clear-screen=false --ignore \"projects/**\" --ignore \"temp/**\" --ignore \"client/**\" --ignore \"**/*.log\" --ignore \"**/dist/**\" --ignore \"**/node_modules/**\" server/index.ts",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "prepare-project-deps": "cd modules/source/default-template && npm install",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop sitebuilder-bdpkph",
    "pm2:restart": "pm2 restart sitebuilder-bdpkph",
    "pm2:delete": "pm2 delete sitebuilder-bdpkph"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "archiver": "^7.0.1",
    "basic-ftp": "^6.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "openai": "^4.20.1",
    "serve-handler": "^6.1.5",
    "sharp": "^0.34.5",
    "ssh2-sftp-client": "^12.1.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/serve-handler": "^6.1.4",
    "@types/ssh2-sftp-client": "^9.0.6",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
