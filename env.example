# OpenAI API для генерации текстов
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5

# Модели для разных типов страниц (опционально, если не указано - используется OPENAI_MODEL)
OPENAI_MODEL_HOMEPAGE=gpt-5
OPENAI_MODEL_CASINO=gpt-5
OPENAI_MODEL_SLOTS=gpt-5
OPENAI_MODEL_GAMES=gpt-5
OPENAI_MODEL_BETTING=gpt-5
OPENAI_MODEL_APP=gpt-5
OPENAI_MODEL_LOGIN=gpt-5
# FAQ (авто- и ручная генерация). Если gpt-5 даёт пустой ответ — укажите gpt-4o-mini
# OPENAI_MODEL_FAQ=gpt-4o-mini

# Runware API для генерации изображений
RUNWARE_API_KEY=your_runware_api_key_here
RUNWARE_API_URL=https://api.runware.ai/v1
RUNWARE_MODEL=flux.1
# Таймаут одного запроса Runware (мс), по умолчанию 180000 (3 мин)
# RUNWARE_REQUEST_TIMEOUT_MS=180000

# Картинки: runware (по умолчанию) или placeholder — локальные WebP-заглушки без Runware
# IMAGE_PROVIDER=placeholder

# OpenAI модель для генерации ALT и TITLE для изображений
OPENAI_MODEL_ALTTITLE=gpt-5

# Сервер
PORT=3001

# Упаковка архивов проектов (ZIP при скачивании / сборке): 1 быстрее, 9 сильнее сжимает и медленнее. По умолчанию backend использует уровень 6.
# SITEBUILDER_ZIP_LEVEL=6

# Таймаут production-сборки dist (vite / npm run build), миллисекунды. По умолчанию 25 мин; 0 — без ограничения (не рекомендуется, если сборка «висит»).
# SITEBUILDER_BUILD_TIMEOUT_MS=1500000

# Ускорение автогенерации: одновременные запросы к OpenAI (тексты страниц × локали). По умолчанию 5 (1–20).
# При лимитах rate limit / 429 уменьшите значение.
# SITEBUILDER_GEN_CONCURRENCY=5
# Одновременные генерации изображений по страницам (Runware). По умолчанию 3 (1–10).
# SITEBUILDER_IMAGE_CONCURRENCY=3

# Референс-тексты: каждый сайт генерируется на основе реальных текстов из
# docs/text-reference (берётся N случайных файлов, для каждой страницы — её лист
# Главная/Казино/Ставки/... как образец стиля и структуры). Модель пишет свой
# оригинальный контент. Включено по умолчанию.
# SITEBUILDER_USE_REFERENCE_TEXTS=true
# Сколько референс-файлов брать на проект (1–6). По умолчанию 3.
# SITEBUILDER_REFERENCE_COUNT=3
# Максимум символов из одного референс-листа в промпте (300–4000). По умолчанию 1100.
# Меньше = дешевле (меньше токенов), но меньше контекста для модели.
# SITEBUILDER_REFERENCE_MAX_CHARS=1100

# Оценка стоимости автогенерации (USD, приблизительно)
# SITEBUILDER_COST_OPENAI_DEFAULT_PER_1K=0.001
# SITEBUILDER_COST_GPT4O_MINI_PER_1K=0.0003
# SITEBUILDER_COST_GPT4O_PER_1K=0.005
# SITEBUILDER_COST_GPT5_PER_1K=0.005
# SITEBUILDER_COST_RUNWARE_PER_IMAGE=0.04

# SEO Entity Layer (schema.org в index.html): настройки в project-settings.json → seoEntity.
# sameAs только из officialProfiles; reviewSources не в sameAs (страница /verification/).
# После правок SEO сохраните проект или пересоберите страницы — вызывается syncIndexHtmlHead.

# Клиент (client/.env или корневой .env с префиксом VITE_):
# Оставьте пустым при npm run dev — Vite проксирует /api на PORT.
# VITE_API_URL=http://127.0.0.1:3001

