[Unit]
Description=Keitaro Web Panel
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/keitaro-web-panel
EnvironmentFile=/opt/keitaro-web-panel/.env
ExecStart=/opt/keitaro-web-panel/.venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
